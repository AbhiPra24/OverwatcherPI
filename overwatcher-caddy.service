[Unit]
Description=OverwatcherPI Caddy Reverse Proxy
After=network.target overwatcher-dashboard.service

[Service]
Type=simple
User=root
WorkingDirectory=/mnt/usb-storage/Work/OverwatcherPI/dashboard
ExecStart=/usr/bin/caddy run --config /mnt/usb-storage/Work/OverwatcherPI/dashboard/Caddyfile
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
